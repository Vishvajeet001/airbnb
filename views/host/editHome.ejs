<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Home</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <header>
        <%- include('../partials/nav.ejs') %>
    </header>
    <main>
        <form action="/host/editHome/<%= home.id %>" method="POST" enctype="multipart/form-data">
            <input type="text" name="name" value="<%= home.name %>" placeholder="Enter home name..."><br>
            <input type="number" name="price" value="<%= home.price %>" placeholder="Enter price per day..."><br>
            <input type="text" name="location" value="<%= home.location %>" placeholder="Enter full location..."><br>
            <input type="number" name="rating" value="<%= home.rating %>" placeholder="Enter rating..."><br>
            <label for="fileInput" class="custom-file-label">
                Upload home pictures...
              </label>
              <input
                type="file"
                id="fileInput"
                name="photos"
                class="hidden-file-input"
                multiple
                accept="image/*"
              /><br>
            <textarea type="text" name="description" placeholder="Enter home description..."><%= home.description %></textarea><br>
            <input type="submit" id="add-btn" value="Update">
        </form>
    </main>

</body>

</html>